        //PlotGlobalTrackletFit(tracklets, "TrackletReco");
        

        // group by trackID
        std::map<int, std::vector<Hit>> trackHits;
        for (const auto& hit : hits) {
            trackHits[hit.trackID].push_back(hit);
        }
        // Process each track separately
        for (const auto& entry : trackHits) {
            int trackID = entry.first;
            const auto& trackHitsVec = entry.second;

            // Require at least 3 stations for valid reconstruction
            std::set<int> uniqueStations;
