// Circle fit in (y, z) plane for Bx field
// Returns the momentum in GeV/c
// fitting the (Y, Z) plane for Bx field.
double TrackAnalysis::CircleFitMomentum_Bx(const std::vector<Hit>& hits, double bx_field) {
    // Need at least 3 hits for a circle fit
    if (hits.size() < 3) return -999.;

    // Set up sums for Kåsa method
    double sum_y = 0, sum_z = 0, sum_yy = 0, sum_zz = 0, sum_yz = 0, sum_r2 = 0;
    double sum_y_r2 = 0, sum_z_r2 = 0;
    int n = 0;

    for (const auto& hit : hits) {
        double y = hit.position.Y();
        double z = hit.position.Z();
        double r2 = y*y + z*z;
        sum_y += y;
        sum_z += z;
        sum_yy += y*y;
        sum_zz += z*z;
        sum_yz += y*z;
        sum_r2 += r2;
        sum_y_r2 += y*r2;
        sum_z_r2 += z*r2;
        n++;
    }

    // Solve for circle center (yc, zc)
    // Based on Kåsa's method for algebraic circle fit
    double A = n * sum_yy - sum_y * sum_y;
    double B = n * sum_yz - sum_y * sum_z;
    double C = n * sum_zz - sum_z * sum_z;
    double D = 0.5 * (n * sum_y_r2 - sum_y * sum_r2);
    double E = 0.5 * (n * sum_z_r2 - sum_z * sum_r2);

    double det = A*C - B*B;
    if (std::abs(det) < 1e-12) {
        // Fallback to -999 on singularity
        return -999.;
    }

    double yc = (D*C - B*E) / det;
    double zc = (A*E - B*D) / det;

    // Compute radius
    double sum_r = 0;
    for (const auto& hit : hits) {
        double dy = hit.position.Y() - yc;
        double dz = hit.position.Z() - zc;
        sum_r += std::sqrt(dy*dy + dz*dz);
    }
    double R = sum_r / n; // Average distance to center

    // Momentum formula: p [GeV/c] = 0.3 * B[T] * R[m]
    // If coordinates are in mm, convert to m
    double R_m = R * 0.001;
    double p = 0.3 * std::abs(bx_field) * R_m;

    // Optional: print results for debugging
    std::cout << "Circle center (yc, zc): (" << yc << ", " << zc << "), R = " << R << " mm, p = " << p << " GeV/c" << std::endl;

    return p;
}


